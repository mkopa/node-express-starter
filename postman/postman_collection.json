        {
          "listen": "test",
          "script": {
            "exec": [
              "// Save token from response for next request",
              "if (pm.response.code === 201) {",
              "    const response = pm.response.json();",
              "    pm.environment.set('password_token', response.token);",
              "    console.log('Token saved:', response.token);",
              "}"
