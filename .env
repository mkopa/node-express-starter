# ===========================================
# BOARDING SERVICE CONFIGURATION
# ===========================================

# -------------------------------------------
# MySQL Database Configuration
# -------------------------------------------
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=boarding
MYSQL_USER=boarding_user
MYSQL_PASSWORD=boarding_pass

# Database connection (used by app)
DB_HOST=db
DB_PORT=3306
DB_USER=boarding_user
DB_PASSWORD=boarding_pass
DB_NAME=boarding

# -------------------------------------------
# Application Configuration
# -------------------------------------------
PORT=3000
NODE_ENV=development

ALLOWED_ORIGINS=http://localhost:3000,https://example.com

# -------------------------------------------
# Security: Basic Auth for Internal Endpoints
# -------------------------------------------
# Credentials required for /api/v1/internal/* endpoints
APP_BASIC_USER=internal-client
APP_BASIC_PASSWORD=supersecretpassword

JWT_SECRET=your-super-secret-key-min-32-chars
JWT_EXPIRY=24h

# -------------------------------------------
# Token Configuration
# -------------------------------------------
# Password reset token expiry time (in hours)
TOKEN_EXPIRY_HOURS=12

# -------------------------------------------
# Password Hashing Algorithm
# -------------------------------------------
# Options: argon2 (recommended), bcrypt
# Argon2 is OWASP recommended for password hashing
PASSWORD_HASH_ALGO=argon2

# -------------------------------------------
# Logging
# -------------------------------------------
# Options: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=debug

# -------------------------------------------
# Rate Limiting (in-memory)
# -------------------------------------------
# Max requests per minute per IP for internal endpoints
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# ===========================================
# DEVELOPMENT NOTES
# ===========================================
# 
# 1. In production, use strong passwords and secrets
# 2. Store sensitive data in secret management systems (Vault, AWS Secrets Manager)
# 3. Enable HTTPS/TLS in production
# 4. Use Redis for distributed rate limiting
# 5. Configure proper CORS headers
# 6. Enable request logging to external systems (ELK, Datadog)
# 7. Set NODE_ENV=production
# 8. Use connection pooling with proper limits
# 9. Enable database SSL/TLS connections
# 10. Implement proper monitoring and alerting